      "width": 400,
      "height": 30,
      "fontSize": 18,
      "fontFamily": 5,
      "text": "🔒 PydanticAI: Type-Safe Firewall",
      "strokeColor": "#2b8a3e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "pydantic-features",
      "type": "text",
      "x": 120,
      "y": 450,
      "width": 660,
      "height": 60,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "✓ Prevents LLM hallucination at parameter level (invalid time format, wrong meds)\n✓ Structured exceptions before API invocation (not silent errors)\n✓ Context injection: KMS proxy, role tier, approved contacts (no global state)\n✓ Enforces typed tool signatures: LLM → Pydantic → External API",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
      "id": "why-temporal-box",
      "type": "rectangle",
      "x": 820,
      "y": 195,
      "width": 700,
      "height": 180,
      "strokeColor": "#2b8a3e",
