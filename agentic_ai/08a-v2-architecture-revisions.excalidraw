      "roundness": {"type": 2, "value": 8}
    },
    {
      "id": "why-temporal-title",
      "type": "text",
      "x": 840,
      "y": 215,
      "width": 600,
      "height": 30,
      "fontSize": 18,
      "fontFamily": 5,
      "text": "✅ Why Temporal Supersedes Lobster",
      "strokeColor": "#2b8a3e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "why-temporal-1",
      "type": "text",
      "x": 840,
      "y": 250,
      "width": 660,
      "height": 25,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "1️⃣ Crash Tolerance: Lobster resumeToken requires Gateway → restart = invalid.\n   Temporal event log persists independently of process.",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
      "id": "why-temporal-2",
      "type": "text",
      "x": 840,
      "y": 285,
      "width": 660,
      "height": 25,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "2️⃣ Temporal Decoupling: Caregiver approval takes hours/days.\n   Temporal pauses with zero resources; Lobster in-memory risk = timeout.",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
      "id": "why-temporal-3",
      "type": "text",
      "x": 840,
      "y": 320,
      "width": 660,
      "height": 35,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "3️⃣ Distributed Scheduling: Temporal native replaces Node.js heartbeat.\n   Same fault-tolerance for cron-triggered wellness checks.\nLobster retained: Synchronous shell within Temporal activity functions.",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
      "id": "composite-box",
      "type": "rectangle",
