    {
      "id": "composite-title",
      "type": "text",
      "x": 840,
      "y": 415,
      "width": 600,
      "height": 30,
      "fontSize": 18,
      "fontFamily": 5,
      "text": "🔧 Composite Architecture: Mathematical Safety Guarantees",
      "strokeColor": "#1864ab",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "composite-text",
      "type": "text",
      "x": 840,
      "y": 450,
      "width": 660,
      "height": 85,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "Temporal guarantees: No workflow is lost (durable execution)\nPydanticAI guarantees: No step executes with invalid parameters (type-safe)\nTogether: Mathematically provable safety neither achieves alone.\n\nWorkflow: User request → Temporal → PydanticAI validation → API → Caregiver approval → Resume",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
