      "width": 700,
      "height": 35,
      "fontSize": 22,
      "fontFamily": 5,
      "text": "🎤 Voice AI Revolution: IndicConformer vs. Whisper",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
