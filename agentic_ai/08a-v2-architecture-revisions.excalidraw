      "width": 660,
      "height": 25,
      "fontSize": 13,
      "fontFamily": 5,
      "text": "Timeline: G-NEW-01: 5-6 weeks | Port 5 core Lobster workflows to Temporal Definitions",
      "strokeColor": "#2b8a3e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
