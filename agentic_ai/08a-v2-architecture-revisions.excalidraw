    {
      "id": "temporal-features",
      "type": "text",
      "x": 120,
      "y": 250,
      "width": 660,
      "height": 60,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "✓ Event sourcing: Every action recorded in immutable event history\n✓ Crash tolerance: Workflow resumes after server restart (unlike Lobster)\n✓ Zero-compute waits: 72-hour caregiver approval gates consume no resources\n✓ Distributed scheduling: Replaces Node.js heartbeat runner (V1 Section 9.2)",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
