    {
      "id": "privacy-text",
      "type": "text",
      "x": 0.30612244897952223,
      "y": 924.5408163265306,
      "width": 1477.9591836734694,
      "height": 54.33673469387755,
      "fontSize": 17.387755102040817,
      "fontFamily": 5,
      "text": "✅ Consent Layer: Explicit recorded consent (voice/tap) for each data processing category\n✅ Data Minimisation: LLM receives only context required for immediate task\n✅ Right to Erasure: \"Forget Everything\" command → Full deletion across all layers + signed certificate\n✅ Data Residency: Indian data centres (Mumbai/Hyderabad AWS) for enterprise/healthcare tiers",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "version": 35,
      "versionNonce": 468234069,
