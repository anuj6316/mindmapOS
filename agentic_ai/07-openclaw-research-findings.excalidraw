    {
      "id": "comparison-title",
      "type": "text",
      "x": 100,
      "y": 650,
      "width": 600,
      "height": 30,
      "fontSize": 20,
      "fontFamily": 5,
      "text": "⚖️ Pros vs. Cons: What We Keep vs. What We Discard",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "pros-header",
      "type": "rectangle",
      "x": 100,
      "y": 690,
      "width": 680,
      "height": 45,
      "strokeColor": "#2b8a3e",
      "fillStyle": "solid",
      "backgroundColor": "#b2f2bb",
      "strokeWidth": 2,
      "roundness": {"type": 2, "value": 8}
    },
    {
      "id": "pros-header-text",
      "type": "text",
      "x": 120,
      "y": 712,
      "width": 640,
      "height": 25,
      "fontSize": 18,
      "fontFamily": 5,
      "text": "✅ PROS (What We Keep)",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "pros-list",
      "type": "text",
      "x": 120,
      "y": 745,
      "width": 640,
      "height": 90,
      "fontSize": 14,
      "fontFamily": 5,
      "text": "• Typed WebSocket API + role-based device authentication\n• Lobster Engine (perfect for elder-user safety flows)\n• MCP Integration (healthcare/caregiver API ready)\n• AGENTS.md/SOUL.md (auditable prompt architecture)\n• Multi-channel orchestration (WhatsApp, Telegram, Slack, Discord)\n• Heartbeat Scheduler (proactive reminders - architecturally correct)",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
      "id": "cons-header",
      "type": "rectangle",
      "x": 800,
      "y": 690,
      "width": 700,
      "height": 45,
      "strokeColor": "#e03131",
      "fillStyle": "solid",
      "backgroundColor": "#ffc9c9",
      "strokeWidth": 2,
      "roundness": {"type": 2, "value": 8}
    },
    {
      "id": "cons-header-text",
      "type": "text",
      "x": 820,
      "y": 712,
      "width": 660,
      "height": 25,
      "fontSize": 18,
      "fontFamily": 5,
      "text": "❌ CONS (What We Discard)",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "cons-list",
      "type": "text",
      "x": 820,
      "y": 745,
      "width": 660,
      "height": 90,
      "fontSize": 14,
      "fontFamily": 5,
      "text": "• Default Port 18789 (RCE attacks within minutes of deployment)\n• ClawHub (341/3000 malicious skills - 11% infection rate)\n• Infinite session-append memory (Context Rot, $16+/user/month)\n• Public Gateway by default (18,000+ exposed instances)\n• No voice interface capability\n• No scam/social engineering detection\n• Developer-oriented UI (unsuitable for non-technical caregivers)",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
      "id": "adaptations-title",
      "type": "text",
      "x": 100,
      "y": 860,
      "width": 700,
      "height": 30,
      "fontSize": 18,
      "fontFamily": 5,
      "text": "🔧 Our Adaptations for Accessible Agentic AI",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "adapt1",
      "type": "rectangle",
