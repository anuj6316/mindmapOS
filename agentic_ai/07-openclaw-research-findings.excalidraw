      "fontSize": 14,
      "fontFamily": 5,
      "text": "🔒 VPC-Private Gateway only\nNO public port exposure (architecturally impossible for Elder User)",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
    {
