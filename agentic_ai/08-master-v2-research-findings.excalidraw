      "width": 400,
      "height": 25,
      "fontSize": 15,
      "fontFamily": 5,
      "text": "❌ V1: Lobster Engine (OpenClaw)",
      "strokeColor": "#c92a2a",
      "fillStyle": "solid",
      "backgroundColor": "transparent",
