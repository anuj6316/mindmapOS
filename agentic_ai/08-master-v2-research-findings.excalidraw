      "fillStyle": "solid",
      "backgroundColor": "transparent",
      "fontWeight": "bold"
    },
    {
      "id": "revision1-v2-detail",
      "type": "text",
      "x": 120,
      "y": 500,
      "width": 840,
      "height": 40,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "Temporal: Crash-tolerant, zero-compute waits, distributed scheduling.\nPydanticAI: Type-safe firewall. Timeline: G-NEW-01: 5-6 weeks.",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
