      "type": "text",
      "x": 120,
      "y": 350,
      "width": 830,
      "height": 40,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "V1 Section 4.3, 9.2: Adopt Lobster with Node.js→Rust heartbeat rewrite.\nProblem: resumeToken requires Gateway active; server restart = lost state.",
      "strokeColor": "#1e1e1e",
      "fillStyle": "solid",
      "backgroundColor": "transparent"
    },
